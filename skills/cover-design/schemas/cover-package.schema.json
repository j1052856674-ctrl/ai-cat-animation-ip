{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cover-package.schema.json",
  "title": "Cover Package",
  "description": "封面包装模块产出的封面方案包，04-cover 最终交接物",
  "type": "object",
  "required": ["package_id", "script_id", "cover_texts", "titles", "ai_prompt"],
  "properties": {
    "package_id": {
      "type": "string",
      "description": "封面包唯一标识，格式 cover-{YYYYMMDD}-{序号}",
      "pattern": "^cover-\\d{8}-\\d{3}$"
    },
    "script_id": {
      "type": "string",
      "description": "关联脚本大纲ID"
    },
    "cover_texts": {
      "type": "array",
      "description": "封面大字方案（至少3个方向）",
      "items": {
        "type": "object",
        "required": ["main_text", "direction_type"],
        "properties": {
          "main_text": {
            "type": "string",
            "description": "核心大字（6-10字）",
            "minLength": 4,
            "maxLength": 15
          },
          "sub_text": {
            "type": "string",
            "description": "副文案，可选辅助信息",
            "maxLength": 20
          },
          "direction_type": {
            "type": "string",
            "description": "封面公式类型",
            "enum": ["数字冲击", "痛点反问", "结果承诺", "矛盾冲突"]
          },
          "layout_hint": {
            "type": "string",
            "description": "排版建议：文字位置、大小比例、与图片主体的关系",
            "maxLength": 100
          }
        }
      },
      "minItems": 3
    },
    "titles": {
      "type": "object",
      "description": "跨平台标题",
      "required": ["xiaohongshu", "douyin"],
      "properties": {
        "xiaohongshu": {
          "type": "string",
          "description": "小红书标题，<=20字，干货感+利他性+emoji",
          "maxLength": 30
        },
        "douyin": {
          "type": "string",
          "description": "抖音标题，<=30字，情绪强+钩子猛",
          "maxLength": 40
        },
        "bilibili": {
          "type": "string",
          "description": "B站标题，<=40字，信息量大+关键词搜索",
          "maxLength": 50
        }
      }
    },
    "descriptions": {
      "type": "object",
      "description": "跨平台描述文案",
      "properties": {
        "xiaohongshu": {
          "type": "string",
          "description": "正文文案+末尾标签#话题1 #话题2，转化指令不放中间",
          "maxLength": 500
        },
        "douyin": {
          "type": "string",
          "description": "简介文案+话题标签+@引导",
          "maxLength": 200
        },
        "bilibili": {
          "type": "string",
          "description": "完整说明文案，含章节时间戳",
          "maxLength": 1000
        }
      }
    },
    "ai_prompt": {
      "type": "object",
      "description": "封面图AI生成提示词",
      "required": ["subject", "style", "composition", "color", "mood"],
      "properties": {
        "subject": {
          "type": "string",
          "description": "主体描述（阿饱+场景+动作）",
          "maxLength": 150
        },
        "style": {
          "type": "string",
          "description": "风格，参考账号视觉风格",
          "maxLength": 80
        },
        "composition": {
          "type": "string",
          "description": "构图，留白位置留给封面大字",
          "maxLength": 100
        },
        "color": {
          "type": "string",
          "description": "色彩倾向（暖黄+白+深灰为主）",
          "maxLength": 60
        },
        "mood": {
          "type": "string",
          "description": "情绪/氛围，匹配脚本情绪基调",
          "maxLength": 40
        }
      }
    },
    "tags": {
      "type": "object",
      "description": "跨平台标签建议",
      "properties": {
        "xiaohongshu": {
          "type": "array",
          "description": "小红书标签（3-5个）",
          "items": { "type": "string" },
          "minItems": 3,
          "maxItems": 5
        },
        "douyin": {
          "type": "array",
          "description": "抖音标签（2-3个+1个IP标签）",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 4
        },
        "bilibili": {
          "type": "array",
          "description": "B站标签（5-10个）",
          "items": { "type": "string" }
        }
      }
    }
  }
}
